# Nyuchi Design Portal — Environment Variables
# Copy this to .env.local and fill in your Supabase credentials.

# ── Supabase (required for database-backed registry) ──────────────────
# Get these from: Supabase Dashboard → Settings → API

# Public client (safe for browser, respects RLS)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only admin key (bypasses RLS). Optional — only needed for write
# operations such as `pnpm registry:sync` or POST /api/v1/fundi. Read
# endpoints work with the anon key alone.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Fundi (optional) ──────────────────────────────────────────────────
# Shared secret for POST /api/v1/fundi (issue creation). Endpoint is
# disabled if unset.
# FUNDI_API_KEY=

# ── Stytch B2B Auth (required for /fundi dashboard) ───────────────────
# Used to gate /fundi/* — the observability-as-a-service dashboard.
# All other routes (registry, MCP, brand, docs) remain public.
# Get these from: https://stytch.com/dashboard → Project → API Keys

# Server-only credentials
STYTCH_PROJECT_ID=project-test-...
STYTCH_SECRET=secret-test-...

# Public token — safe for browser, scoped to client-side SDK calls
NEXT_PUBLIC_STYTCH_PUBLIC_TOKEN=public-token-test-...

# ── Port (optional, defaults to 11736) ────────────────────────────────
# PORT=11736
